<h2><%= @task.title %></h2>
<p><%= @task.details %></p>
<p>Task completed? <%= @task.completed %></p>


<%= link_to "Delete this task", task_path(@task), data: {turbo_method: :delete, turbo_confirm: "Are you sure?"} %>

<%= link_to "Back to all tasks", tasks_path %>

<%= link_to "Edit this task", edit_path %>
